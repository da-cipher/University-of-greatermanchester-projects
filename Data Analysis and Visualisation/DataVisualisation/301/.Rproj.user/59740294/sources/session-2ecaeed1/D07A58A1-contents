  filter(Rank <= 5)

ggplot(species_year_top,
       aes(x = CalendarYear,
           y = Rank,
           colour = Species)) +
  geom_bump(size = 1) +
  geom_point(size = 2) +
  scale_y_reverse(breaks = 1:5) +                   # 1 = top
  facet_wrap(~ Commodity) +
  labs(title   = "Rank of Top-5 Seafood Species",
       x = "Calendar year",
       y = "Rank",
       colour = "Species") +
  theme_minimal(base_size = 11) +
  theme(legend.position = "right")


```



# Further analysis
##What is the correlation between seafood production and total trade volume

```{r}
# aggregate to annual totals
annual_totals <- cleanseafood_data |>
  filter(Commodity %in% c("Production", "Imports", "Exports")) |>
  mutate(TradeFlag = if_else(Commodity == "Production", "Production", "Trade")) |>
  group_by(CalendarYear, TradeFlag) |>
  summarise(Total_tonne = sum(Volume_tonne, na.rm = TRUE), .groups = "drop") |>
  pivot_wider(names_from = TradeFlag, values_from = Total_tonne)

print(annual_totals)

# correlation tests 
pearson_res  <- cor.test(annual_totals$Production,
                         annual_totals$Trade,
                         method = "pearson")
print(pearson_res)

spearman_res <- cor.test(annual_totals$Production,
                         annual_totals$Trade,
                         method = "spearman")
print(spearman_res)

corr_tbl <- bind_rows(
  tidy(pearson_res)  |> mutate(Method = "Pearson"),
  tidy(spearman_res) |> mutate(Method = "Spearman")
) |>
  select(Method, estimate, p.value, conf.low, conf.high)

print(corr_tbl)
```



