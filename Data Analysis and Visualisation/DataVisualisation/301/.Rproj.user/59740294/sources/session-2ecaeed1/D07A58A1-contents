#forecasting

```{r}

# annual production ts
production_data <- cleanseafood_data %>%
  filter(Commodity == "Production") %>%
  group_by(CalendarYear) %>%
  summarise(Total = sum(Volume_tonne, na.rm=TRUE), .groups="drop")

prod_ts <- ts(production_data$Total, start = min(production_data$CalendarYear), frequency = 1)

# Fit ARIMA and forecast 5 years
arima_model   <- auto.arima(prod_ts, stepwise=FALSE, approximation=FALSE)
arima_fc      <- forecast(arima_model, h=5)


# combined history + forecast dataframe
forecast_df <- bind_rows(
  production_data %>%
    rename(year = CalendarYear) %>%
    mutate(type = "history"),
  
  tibble(
    year      = (max(production_data$CalendarYear) + 1):(max(production_data$CalendarYear) + 5),
    Total     = as.numeric(arima_fc$mean),
    lower     = as.numeric(arima_fc$lower[,2]),
    upper     = as.numeric(arima_fc$upper[,2]),
    type      = "forecast"
  )
) %>%
  arrange(year)

#continuous line connecting history + forecast
ggplot(forecast_df, aes(x = year, y = Total, group = 1)) +
  geom_line(size = 1, colour = "steelblue") +  
  geom_point(aes(colour = type), size = 3) +
  geom_ribbon(
    data = filter(forecast_df, type == "forecast"),
    aes(ymin = lower, ymax = upper),
    fill = "cyan", alpha = 0.2
  ) +
  scale_colour_manual(values = c(history = "blue", forecast = "red")) +
  labs(
    title   = "UK Seafood Production Forecast (2021–2025) – ARIMA",
    x       = "Year",
    y       = "Production Volume (tonnes)",
    colour  = ""
  ) +
  theme_bw(base_size = 12)

```


```{r}

# annual production series
production_data <- cleanseafood_data %>%
  filter(Commodity == "Production") %>%
  group_by(CalendarYear) %>%
  summarise(Total = sum(Volume_tonne, na.rm = TRUE), .groups="drop")

prod_ts <- ts(production_data$Total, 
              start = min(production_data$CalendarYear), 
              frequency = 1)

#Holt's linear ETS (additive trend)
ets_model <- ets(prod_ts, model = "AAN")
ets_fc <- forecast(ets_model, h = 5)

history_prod_df <- tibble(
  Year  = time(prod_ts),
  Value = as.numeric(prod_ts),
  Type  = "history"
)

forecast_prod_df <- tibble(
  Year  = as.integer(time(ets_fc$mean)),
  Value = as.numeric(ets_fc$mean),
  Lower = as.numeric(ets_fc$lower[,2]),
  Upper = as.numeric(ets_fc$upper[,2]),
  Type  = "forecast"
)

combined_prod <- bind_rows(history_prod_df, forecast_prod_df)

ggplot(combined_prod, aes(x = Year, y = Value)) +
  geom_line(colour = "steelblue", size = 1) +
  geom_point(aes(colour = Type), size = 3) +
  geom_ribbon(data = filter(combined_prod, Type == "forecast"),
              aes(ymin = Lower, ymax = Upper),
              fill = "cyan", alpha = 0.2) +
  scale_colour_manual(values = c(history = "blue", forecast = "red")) +
  labs(
    title    = "UK Seafood Production Forecast (2021–2025)",
    subtitle = "Holt’s Linear ETS",
    x        = "Year",
    y        = "Production (tonnes)"
  ) +
  theme_bw(base_size = 12)

```

```{r}

#Compare AIC
aic_vals <- data.frame(
  Model = c("ARIMA", "ETS"),
  AIC   = c(AIC(arima_model), AIC(ets_model))
)
print(aic_vals)

#Compare accuracy
acc_arima <- accuracy(arima_model)
acc_ets   <- accuracy(ets_model)
acc_df    <- data.frame(
  Model = rep(c("ARIMA","ETS"), each=ncol(acc_arima)),
  Metric= colnames(acc_arima),
  ARIMA  = as.numeric(acc_arima[1,]),
  ETS    = as.numeric(acc_ets[1,])
)
print(acc_df)

fc_combined <- ts.union(
  ARIMA = arima_fc$mean,
  ETS   = ets_fc$mean
)

autoplot(prod_ts, series="Actual") +
  autolayer(fc_combined, series=c("ARIMA","ETS")) +
  labs(title="Production: Actual vs ARIMA & ETS Forecasts",
       x="Year", y="Production (tonnes)") +
  scale_colour_manual(values=c("Actual"="black","ARIMA"="grey50","ETS"="blue")) +
  theme_minimal()

```





