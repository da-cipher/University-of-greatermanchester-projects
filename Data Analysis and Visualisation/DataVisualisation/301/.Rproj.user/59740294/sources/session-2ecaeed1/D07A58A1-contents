# Getting and understanding the Data

```{r}
getwd()

# Load dataset
seafood_data <- read.csv("UKSeafoodSupplyChain.csv")

# Summarise the dataset 
summary(seafood_data)

sum(is.na(seafood_data))

# Count NA's in each column
na_per_col <- colSums(is.na(seafood_data))
print(na_per_col)
```

# Data Preparation and Cleaning

```{r}
# Identify rows with missing values in any column
missing_rows <- seafood_data[rowSums(is.na(seafood_data)) > 0, ]

# View the rows with missing values
print(missing_rows)
```

```{r}
# Impute missing production volumes 
seafood_filled <- seafood_data |> 
  group_by(Species, Commodity) |>                     
  mutate(
    Volume = ifelse(                                   
      is.na(Volume) & Commodity == "Production",       
      mean(Volume, na.rm = TRUE),                     
      Volume                                           
    )
  ) |> 
  ungroup() 

sum(is.na(seafood_filled))

```

```{r}
#Remove unnecessary columns, convert to tonnes and drop Purchases and Consumption
cleanseafood_data <- seafood_filled |> select(-TemporalResolution, -Flag, -FlagDescription, -DataSupplier, -DataSet, -Units, -SpeciesType, -SACN) 

cleanseafood_data <- cleanseafood_data |>
  mutate(Volume_tonne = Volume / 1e6) |>    #grams to tonnes
  select(-Volume) |>
  filter(!Commodity %in% c("Purchases", "Consumption"))

head(cleanseafood_data)
```

```{r}
# Check for duplicate rows
duplicates <- seafood_filled[duplicated(seafood_filled), ]

print(duplicates)
```


# Exploratory Data Analysis (EDA)

```{r}
summary_stats <- cleanseafood_data |>
  group_by(CalendarYear, Commodity) |>
  summarise(Mean_Volume = mean(Volume_tonne), 
            Median_Volume = median(Volume_tonne),
            SD_Volume = sd(Volume_tonne),
            Count = n(),
            .groups = "drop")

print(summary_stats)

ggplot(summary_stats, aes(x = CalendarYear, y = Mean_Volume, color = Commodity)) +
  geom_line(linewidth = 1) +
  geom_point(size = 2) +
  labs(title = "Mean Seafood Volume by Year and Commodity",
       x = "Year", y = "Mean Volume (tonnes)",
       color = "Commodity") +
  theme_minimal() +
  theme(legend.position = "right")
```

```{r}
# Summarise all trade volumes by Commodity and Year
all_trade <- cleanseafood_data |>
  group_by(Commodity, CalendarYear) |>  # Grouping by Commodity and Calendar Year
  summarise(Total_Volume = sum(Volume_tonne, na.rm = TRUE), .groups = "drop") 

print(all_trade)

# Keep only Imports & Exports, then aggregate by year
trade_IE <- cleanseafood_data %>% 
  filter(Commodity %in% c("Imports", "Exports")) %>% 
  group_by(CalendarYear, Commodity) %>% 
  summarise(Total_Volume = sum(Volume_tonne, na.rm = TRUE), .groups = "drop")

print(trade_IE)

ggplot(trade_IE,
       aes(x = factor(CalendarYear),
           y = Total_Volume,     
           fill = Commodity)) +
  geom_col(position = "dodge") +
  scale_y_continuous(labels = comma) +
  labs(title = "UK Seafood Imports vs Exports by Year",
       x = "Calendar year",
       y = "Total volume",
       fill = "Commodity") +
  theme_minimal(base_size = 12) +
  theme(legend.position = "right")  

```

## Which species dominate the UK seafood exports and imports
```{r}
# Summarise total export and import volumes by species
species_trade <- cleanseafood_data |>
  group_by(Species, Commodity) |>
  summarise(Total_Volume = sum(Volume_tonne, na.rm = TRUE), .groups = "drop") 

print(species_trade)


# Identify dominant species for imports and exports
dominant_exports <- species_trade |>
  filter(Commodity == "Exports") |>
  arrange(desc(Total_Volume)) |>
  head(10) 

print(dominant_exports)

dominant_imports <- species_trade |>
  filter(Commodity == "Imports") |>
  arrange(desc(Total_Volume)) |>
  head(10) 

print(dominant_imports)


# Top 10 Imports bar-plot
p_imports <- ggplot(dominant_imports, aes(x = reorder(Species, Total_Volume), y = Total_Volume)) +
  geom_col(fill = "#4b9cd3") +
  coord_flip() +
  labs(title = "Imports (2009–2020)",
       x = NULL,
       y = "Total Volume (tonnes)") +
  theme_minimal(base_size = 12)

# Top 10 Exports bar-plot
p_exports <- ggplot(dominant_exports, aes(x = reorder(Species, Total_Volume), y = Total_Volume)) +
  geom_col(fill = "#d95f02") +
  coord_flip() +
  labs(title = "Exports (2009–2020)",
       x = NULL,
       y = "Total Volume (tonnes)") +
  theme_minimal(base_size = 12)

# Display side by side
p_imports + p_exports + 
  plot_annotation(
    title = "Dominant Seafood Species",
    theme = theme(plot.title = element_text(size = 14, face = "bold"))
  )
```


