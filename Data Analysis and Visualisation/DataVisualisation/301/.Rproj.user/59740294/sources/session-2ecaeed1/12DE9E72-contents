```{r}
# DETECTING OUTLIERS

# Detecting numeric columns
numericCol <- sapply(HouseData, is.numeric)
numericCol

# Detect outliers using the IQR method
outliers <- sapply(HouseData[, sapply(HouseData, is.numeric)], function(x) {
  Q1 <- quantile(x, 0.25)
  Q3 <- quantile(x, 0.75)
  IQR <- Q3 - Q1
  lower_bound <- Q1 - 1.5 * IQR
  upper_bound <- Q3 + 1.5 * IQR
  sum(x < lower_bound | x > upper_bound)  # Count the number of outliers
})

# Print the number of outliers for each numeric column
print(outliers)

# check to see the individua; columns
HouseData_withFlags <- HouseData
for(col in names(HouseData)) {
  x <- HouseData[[col]]
  Q1 <- quantile(x, 0.25, na.rm = TRUE)
  Q3 <- quantile(x, 0.75, na.rm = TRUE)
  IQR_val <- Q3 - Q1
  lower_bound <- Q1 - 1.5 * IQR_val
  upper_bound <- Q3 + 1.5 * IQR_val
  flag <- ifelse(x < lower_bound | x > upper_bound, 1, 0)
  HouseData_withFlags[[paste0(col, "_outlier")]] <- flag
}
head(HouseData_withFlags)
