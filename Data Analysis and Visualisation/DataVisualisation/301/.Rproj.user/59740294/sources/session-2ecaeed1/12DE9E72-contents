```{r}

# read the data
Housing2 <- read.csv("Housing Data_Same Region.csv")
HouseData2 <- Housing |> select(-LATITUDE, -LONGITUDE, -PARCELNO)

HouseData2 <- HouseData2 |> select(-SALE_PRC, everything(), SALE_PRC)
HouseData2 <- HouseData2[, sapply(HouseData2, is.numeric)]

# Create a preprocessing object for normalization (range: 0 to 1)
# Preprocess only the numeric columns
normal <- preProcess(HouseData2[, -which(names(HouseData2) == "SALE_PRC")], method = "range")

# Apply the normalization model to the numeric data (excluding SALE_PRC column)
HouseData2[, -which(names(HouseData2) == "SALE_PRC")] <- predict(normal, HouseData2[, -which(names(HouseData2) == "SALE_PRC")])

set.seed(123) 
trainSize2 <- sample(1:nrow(HouseData2), size = ceiling(0.8 * nrow(HouseData2)))

trainSet2 <- HouseData2[trainSize, ]
testSet2 <- HouseData2[-trainSize, ]
nrow(trainSet2)

# Define the range for ntree (from 100 to 600 with a step of 1)
ntree_values2 <- seq(100, 600, by = 1)

# Define the tuning grid with mtry fixed at 3
tuneGrid2 <- expand.grid(.mtry = 3)

# Set up cross-validation settingsn
trainControl2 <- trainControl(
  method = "cv",      
  number = 5,         
  search = "grid"     
)

# Initialize list to store results and variables to track the best model
results_list2 <- list()
best_model2 <- NULL
best_rmse2 <- Inf
best_ntree2 <- NULL  # To track the best ntree value

# Loop through each ntree value and train the model, printing progress to the console
for(i in seq_along(ntree_values2)) {
  current_ntree2 <- ntree_values2[i]
  cat("Iteration", i, "of", length(ntree_values2), "- ntree =", current_ntree2, "\n")
  
  # Train the Random Forest model with the current ntree value and fixed mtry = 3
  rf_model2 <- train(
    SALE_PRC ~ .,             # Use SALE_PRC as the target
    data = trainSet2,              # Training data
    method = "rf",                # Random Forest method
    trControl = trainControl2,     # Cross-validation settings
    tuneGrid = tuneGrid2,          # Hyperparameter grid (fixed mtry)
    ntree = current_ntree2,        # Set number of trees for this iteration
    importance = TRUE             # Track feature importance
  )
  
  # Store the model corresponding to the current ntree value
  results_list[[as.character(current_ntree2)]] <- rf_model2
  
  # Find the best RMSE from this model's cross-validation results
  current_rmse2 <- min(rf_model2$results$RMSE)
  if(current_rmse2 < best_rmse2) {
    best_rmse2 <- current_rmse2
    best_model2 <- rf_model2
    best_ntree2 <- current_ntree2  # Track the best ntree value
  }
}

# Save the best model
saveRDS(best_model2, "best_rf_model2.rds")

# Print the best ntree value
cat("Best ntree value:", best_ntree2, "\n")  

# Use the best model to make predictions on the sample data
