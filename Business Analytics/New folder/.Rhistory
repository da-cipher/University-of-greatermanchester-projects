# 13. Moving average smoothing (13-week window)
ma13 <- stats::filter(fuel_clean_ts, rep(1/13, 13), sides = 2)
autoplot(fuel_clean_ts, series = "Cleaned") +
autolayer(ma13, series = "13-Week MA") +
labs(title = "13-Week Moving Average of Cleaned Series", x = "Week Ending") +
theme_minimal()
