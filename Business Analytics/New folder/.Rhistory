# 1. Fit an (auto)ARIMA to the raw series
fit <- auto.arima(fuel_ts)
# 2. Compute residuals and standard deviation
res  <- residuals(fit)
sdev <- sd(res, na.rm = TRUE)
# 3. Identify “outliers” as points where |residual| > 3·σ
threshold <- 3 * sdev
out_idx   <- which(abs(res) > threshold)
# 4. Inspect which weeks these are
week_outliers <- time(fuel_ts)[out_idx]
print(data.frame(index = out_idx, week = week_outliers,
observed = fuel_ts[out_idx],
residual = res[out_idx]))
# Load required libraries
library(readxl)    # for reading Excel
library(dplyr)     # for data manipulation
library(ggplot2)   # for plotting
library(zoo)       # for interpolation (na.approx, na.locf)
library(forecast)  # for outlier detection and cleaning
# 1. Read in the “Table 1 Weekly” sheet, skipping the first 5 rows of metadata
fuel_raw <- read_excel(
path       = "fuel_price.xlsx",
sheet      = "Table 1 Weekly",
skip       = 5,
col_names  = TRUE
)
# 2. Select only date and average fuel price, and rename
fuel <- fuel_raw %>%
select(
week_ending    = `Week ending`,
avg_fuel_price = `Average fuel price`
)
# 3. Convert types: ensure week_ending is Date, avg_fuel_price is numeric
fuel <- fuel %>%
mutate(
week_ending    = as.Date(week_ending),
avg_fuel_price = as.numeric(avg_fuel_price)
)
# 4. Check for missing values
fuel %>% summarise(missing = sum(is.na(avg_fuel_price)))
# 5. Impute interior gaps via linear interpolation
fuel <- fuel %>%
arrange(week_ending) %>%
mutate(
avg_fuel_price = na.approx(avg_fuel_price, na.rm = FALSE)
)
# 7. Convert to a univariate ts object (weekly frequency)
start_year <- as.numeric(format(min(fuel$week_ending), "%Y"))
start_week <- as.numeric(format(min(fuel$week_ending), "%V"))
fuel_ts <- ts(
data      = fuel$avg_fuel_price,
start     = c(start_year, start_week),
frequency = 52
)
# 8. Detect outliers in the series
outliers <- tsoutliers(fuel_ts)
print(outliers)
# 9. Clean the series (replace outliers & residual NAs)
fuel_clean_ts <- tsclean(fuel_ts)
# 10. Visualise original vs cleaned
autoplot(fuel_ts, series = "Original") +
autolayer(fuel_clean_ts, series = "Cleaned") +
labs(
title = "Average Fuel Price: Original vs Cleaned",
x     = "Week Ending",
y     = "Price (pence per litre)"
)
# 11. Merge the cleaned series back into the data frame
fuel <- fuel %>%
mutate(avg_fuel_price_clean = as.numeric(fuel_clean_ts))
# 12. Final check
str(fuel)
View(fuel)
# 11. Merge the cleaned series back into the data frame
fuel_clean <- fuel %>%
mutate(avg_fuel_price_clean = as.numeric(fuel_clean_ts))
fuel_clean <- fuel_clean %>% select(-avg_fuel_price)
# 12. Final check
str(fuel_clean)
# Load required libraries
library(readxl)    # for reading Excel
library(dplyr)     # for data manipulation
library(ggplot2)   # for plotting
library(zoo)       # for interpolation (na.approx, na.locf)
library(forecast)  # for outlier detection and cleaning
# 1. Read in the “Table 1 Weekly” sheet, skipping the first 5 rows of metadata
fuel_raw <- read_excel(
path       = "fuel_price.xlsx",
sheet      = "Table 1 Weekly",
skip       = 5,
col_names  = TRUE
)
# 2. Select only date and average fuel price, and rename
fuel <- fuel_raw %>%
select(
week_ending    = `Week ending`,
avg_fuel_price = `Average fuel price`
)
# 3. Convert types: ensure week_ending is Date, avg_fuel_price is numeric
fuel <- fuel %>%
mutate(
week_ending    = as.Date(week_ending),
avg_fuel_price = as.numeric(avg_fuel_price)
)
# 4. Check for missing values
fuel %>% summarise(missing = sum(is.na(avg_fuel_price)))
# 5. Impute interior gaps via linear interpolation
fuel <- fuel %>%
arrange(week_ending) %>%
mutate(
avg_fuel_price = na.approx(avg_fuel_price, na.rm = FALSE)
)
# 7. Convert to a univariate ts object (weekly frequency)
start_year <- as.numeric(format(min(fuel$week_ending), "%Y"))
start_week <- as.numeric(format(min(fuel$week_ending), "%V"))
fuel_ts <- ts(
data      = fuel$avg_fuel_price,
start     = c(start_year, start_week),
frequency = 52
)
# 8. Detect outliers in the series
outliers <- tsoutliers(fuel_ts)
print(outliers)
# 9. Clean the series (replace outliers & residual NAs)
fuel_clean_ts <- tsclean(fuel_ts)
# 10. Visualise original vs cleaned
autoplot(fuel_ts, series = "Original") +
autolayer(fuel_clean_ts, series = "Cleaned") +
labs(
title = "Average Fuel Price: Original vs Cleaned",
x     = "Week Ending",
y     = "Price (pence per litre)"
)
# 11. Merge the cleaned series back into the data frame
fuel_clean <- fuel %>%
mutate(avg_fuel_price_clean = as.numeric(fuel_clean_ts))
fuel_clean <- fuel_clean %>% select(-avg_fuel_price)
# 12. Final check
str(fuel_clean)
View(fuel)
# 1. Read in the “Table 1 Weekly” sheet, skipping the first 5 rows of metadata
fuel_raw <- read_excel(
path      = "fuel_price.xlsx",
sheet     = "Table 1 Weekly",
skip      = 5,
col_names = TRUE
)
# 2. Select only date and average fuel price, and rename
fuel <- fuel_raw %>%
select(
week_ending    = `Week ending`,
avg_fuel_price = `Average fuel price`
)
# 3. Convert types: ensure week_ending is Date, avg_fuel_price is numeric
fuel <- fuel %>%
mutate(
week_ending    = as.Date(week_ending),
avg_fuel_price = as.numeric(avg_fuel_price)
)
# 4. Check for missing values
fuel %>% summarise(missing = sum(is.na(avg_fuel_price)))
# 5. Impute interior gaps via linear interpolation
fuel <- fuel %>%
arrange(week_ending) %>%
mutate(
avg_fuel_price = na.approx(avg_fuel_price, na.rm = FALSE)
)
# 6. Convert to a univariate ts object (weekly frequency)
start_year <- as.numeric(format(min(fuel$week_ending), "%Y"))
start_week <- as.numeric(format(min(fuel$week_ending), "%V"))
fuel_ts <- ts(
data      = fuel$avg_fuel_price,
start     = c(start_year, start_week),
frequency = 52
)
# 7. Detect outliers in the series
outliers <- tsoutliers(fuel_ts)
print(outliers)
# 8. Clean the series (replace outliers & residual NAs)
fuel_clean_ts <- tsclean(fuel_ts)
# 9. Visualise original vs cleaned
autoplot(fuel_ts, series = "Original") +
autolayer(fuel_clean_ts, series = "Cleaned") +
labs(
title = "Average Fuel Price: Original vs Cleaned",
x     = "Week Ending",
y     = "Price (pence per litre)"
) +
theme_minimal()
# 10. Merge the cleaned series back into the data frame
fuel_clean <- fuel %>%
mutate(avg_fuel_price = as.numeric(fuel_clean_ts))
View(fuel)
View(fuel_clean)
autoplot(decomp_stl) +
labs(title = "STL Decomposition of Cleaned Fuel Price") +
theme_minimal()
# 11. STL decomposition (trend / seasonal / remainder)
decomp_stl <- stl(fuel_clean_ts, s.window = "periodic")
autoplot(decomp_stl) +
labs(title = "STL Decomposition of Cleaned Fuel Price") +
theme_minimal()
# 12. Hodrick–Prescott filter (HP filter)
hp <- hpfilter(fuel_clean_ts, type = "lambda", freq = 129600)
autoplot(fuel_clean_ts, series = "Cleaned") +
autolayer(hp$trend,      series = "HP Trend") +
autolayer(hp$cycle,      series = "HP Cycle") +
labs(title = "HP Filter Decomposition", x = "Week Ending") +
theme_minimal()
