# 1. Read in the “Table 1 Weekly” sheet, skipping the first 5 rows of metadata
fuel_raw <- read_excel(
path      = "fuel_price.xlsx",
sheet     = "Table 1 Weekly",
skip      = 5,
col_names = TRUE
)
# 2. Select only date and average fuel price, then rename
fuel <- fuel_raw %>%
select(
week_ending    = `Week ending`,
avg_fuel_price = `Average fuel price`
)
# 3. Convert types: ensure week_ending is Date, avg_fuel_price is numeric
fuel <- fuel %>%
mutate(
week_ending    = as.Date(week_ending),
avg_fuel_price = as.numeric(avg_fuel_price)
)
# 4. Check for missing values
fuel %>%
summarise(
missing = sum(is.na(avg_fuel_price))
)
# 5. Impute interior gaps via linear interpolation
fuel <- fuel %>%
arrange(week_ending) %>%
mutate(
avg_fuel_price = na.approx(avg_fuel_price, na.rm = FALSE)
)
# 6. Convert to a univariate ts object (weekly frequency)
start_year <- as.numeric(format(min(fuel$week_ending), "%Y"))
start_week <- as.numeric(format(min(fuel$week_ending), "%V"))
fuel_ts <- ts(
data      = fuel$avg_fuel_price,
start     = c(start_year, start_week),
frequency = 52
)
# 7. Detect and print outliers in the series
outliers <- tsoutliers(fuel_ts)
print(outliers)
# 8. Clean the series (replace outliers & any residual NAs)
fuel_clean_ts <- tsclean(fuel_ts)
# 9. Visualise original vs cleaned series
autoplot(fuel_ts, series = "Original") +
autolayer(fuel_clean_ts, series = "Cleaned") +
labs(
title = "Average Fuel Price: Original vs Cleaned",
x     = "Week Ending",
y     = "Price (pence per litre)"
) +
theme_minimal()
# 10. Merge the cleaned series back into a data frame
fuel_clean <- fuel %>%
mutate(avg_fuel_price = as.numeric(fuel_clean_ts))
# 11. STL decomposition (trend / seasonal / remainder)
decomp_stl <- stl(fuel_clean_ts, s.window = "periodic")
autoplot(decomp_stl) +
labs(
title = "STL Decomposition of Cleaned Fuel Price",
x     = "Week Ending"
) +
theme_minimal()
# 12. Hodrick–Prescott filter decomposition
hp <- hpfilter(fuel_clean_ts, type = "lambda", freq = 129600)
autoplot(fuel_clean_ts, series = "Cleaned") +
autolayer(hp$trend, series = "HP Trend") +
autolayer(hp$cycle, series = "HP Cycle") +
labs(
title = "HP Filter Decomposition",
x     = "Week Ending"
) +
theme_minimal()
# 13. Final structure check of cleaned data frame
str(fuel_clean)
# 14.1 Augmented Dickey–Fuller test (H₀: non-stationary)
adf_result <- adf.test(fuel_clean_ts)
print(adf_result)
# 14.2 KPSS test (H₀: level stationary)
kpss_result <- ur.kpss(fuel_clean_ts, type = "tau", lags = "short")
library(urca)      # for KPSS via ur.kpss()
summary(kpss_result)
# 14.2 KPSS test (H₀: level stationary)
kpss_result <- ur.kpss(fuel_clean_ts, type = "tau", lags = "short")
summary(kpss_result)
# 14.3 If non-stationary, difference once
if (adf_result$p.value > 0.05 && kpss_result@teststat > kpss_result@cval["10pct"]) {
fuel_diff1 <- diff(fuel_clean_ts, differences = 1)
# 14.4 Plot the differenced series
autoplot(fuel_diff1) +
labs(
title = "First Difference of Cleaned Fuel Price",
x     = "Week Ending",
y     = "Δ Price"
) +
theme_minimal()
# 14.5 Re-run ADF on differenced series
print(adf.test(fuel_diff1))
# 14.6 Assign differenced series for modelling
ts_for_model <- fuel_diff1
} else {
ts_for_model <- fuel_clean_ts
}
